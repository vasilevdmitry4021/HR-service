# Database (Docker Compose default matches these values)
DATABASE_URL=postgresql://hr:hr@localhost:5432/hr_service

# JWT / security (generate strong secrets for production)
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
TOKEN_ENCRYPTION_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# HeadHunter OAuth (fill when integrating real HH API)
HH_CLIENT_ID=
HH_CLIENT_SECRET=
HH_REDIRECT_URI=http://localhost:8000/api/v1/hh/callback

# Feature flags
FEATURE_USE_MOCK_LLM=false
FEATURE_USE_MOCK_HH=false
# Тест выгрузки в e-staff без реального API (только для разработки)
FEATURE_USE_MOCK_ESTAFF=false
FEATURE_USE_TELEGRAM_SOURCE=false
TELEGRAM_SESSION_ENCRYPTION_KEY=
TELEGRAM_SYNC_ENABLED=true
TELEGRAM_SYNC_INTERVAL_SECONDS=300
TELEGRAM_SYNC_BATCH_SIZE=100
TELEGRAM_MAX_ATTACHMENT_MB=10
TELEGRAM_ALLOWED_ATTACHMENT_TYPES=pdf,docx,doc,txt
TELEGRAM_RESUME_CLASSIFIER_ENABLED=true
TELEGRAM_RESUME_CLASSIFIER_MIN_SCORE=0.6
# Базовый хост задаётся в UI (полный DNS, например krit.e-staff.ru); пути — от корня сайта
ESTAFF_CREATE_CANDIDATE_PATH=/api/candidate/add
# Список вакансий: POST с JSON (Authorization: Bearer)
ESTAFF_VACANCIES_PATH=/api/vacancy/find
# Диапазон дат для списка вакансий задаётся в запросе API (min_start_date, max_start_date) или по умолчанию — текущий календарный год (UTC)
# Проверка TLS к e-staff (true/false; false только для отладки)
ESTAFF_HTTP_VERIFY=true
# В ответе 502 добавить краткую техническую причину (true только для отладки)
ESTAFF_EXPOSE_ERROR_DETAIL=false
# Кэш списка вакансий в памяти backend, секунды (0 = без кэша)
ESTAFF_VACANCIES_CACHE_TTL_SECONDS=120
# Заглушки ФИО и контактов для eStaff, если HH не отдаёт данные (например бесплатный тариф). После апгрейда HH — false.
ESTAFF_FIO_PLACEHOLDER_ENABLED=false
# ESTAFF_FIO_PLACEHOLDER_FIRSTNAME=
# ESTAFF_FIO_PLACEHOLDER_LASTNAME=
# ESTAFF_FIO_PLACEHOLDER_MIDDLENAME=
# ESTAFF_CONTACT_PLACEHOLDER_EMAIL=
# ESTAFF_CONTACT_PLACEHOLDER_MOBILE=
# Публичный URL фронтенда для ссылки в HTML-вложении при выгрузке в e-staff (без / в конце)
# Локально: http://localhost:3000; в проде — https://ваш-домен
HR_PUBLIC_BASE_URL=http://localhost:3000
# type_id типа вложения в e-staff для HTML-блока «HR + ИИ» (get_voc: card_attachment_types)
# По умолчанию add_comment — «Доп. комментарий»; при необходимости замените на свой тип стенда
ESTAFF_HR_BUNDLE_ATTACHMENT_TYPE_ID=add_comment

# LLM — настройте под вашу LLM (Ollama / OpenAI / DeepSeek и т.п.)
# Ollama: INTERNAL_LLM_ENDPOINT=http://host:11434/api/generate, INTERNAL_LLM_API_KEY=ollama
# OpenAI: INTERNAL_LLM_ENDPOINT=https://api.openai.com/v1/chat/completions, INTERNAL_LLM_API_KEY=sk-...
# DeepSeek: INTERNAL_LLM_ENDPOINT=https://api.deepseek.com/v1/chat/completions
INTERNAL_LLM_ENDPOINT=
INTERNAL_LLM_API_KEY=
INTERNAL_LLM_MODEL=
FEATURE_PDF_EXPORT=false
FEATURE_LLM_RESUME_ANALYSIS=true
LLM_RELEVANCE_THRESHOLD=60

# Детальный анализ по снимку (POST /search/{snapshot_id}/analyze)
LLM_SEARCH_BATCH_SIZE=10
LLM_DETAILED_TOP_N=15

# Pre-screening для POST /search/{snapshot_id}/evaluate (должна существовать на сервере LLM)
# Часто совпадает с INTERNAL_LLM_MODEL, если отдельная лёгкая модель не установлена
LLM_FAST_MODEL=qwen3-vl:30b-a3b-instruct
LLM_FAST_BATCH_SIZE=5
# Дозапрос LLM по одному резюме, если в батче не пришла оценка (true/false)
LLM_PRESCORE_REFILL_ENABLED=true
LLM_PRESCORE_REFILL_MAX_LLM_CALLS=500

# Снимок выдачи поиска (пагинация без повторных запросов к HH/LLM в рамках одного поиска)
SEARCH_SNAPSHOT_TTL_SECONDS=3600
SEARCH_SNAPSHOT_MAX_PER_USER=8
SEARCH_MAX_RESUMES_FETCH_PER_SEARCH=1000
SEARCH_HH_PAGE_SIZE=50

# Пост-фильтрация по точным числовым границам из parsed
STRICT_NUMERIC_FILTERS=true
STRICT_FILTER_MODE=hide

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Pytest: отдельная БД для интеграционных тестов
# TEST_DATABASE_URL=postgresql://hr:hr@localhost:5432/hr_service_test
