# Docker Compose — переменные для подстановки в docker-compose.yml
# Скопируйте в .env и при необходимости измените.
# Для полной настройки backend см. backend/.env.example

# Порты (по умолчанию: 5432, 8000, 3000)
# POSTGRES_PORT=5432
# BACKEND_PORT=8000
# FRONTEND_PORT=3000

# База данных (по умолчанию: hr/hr/hr_service)
# POSTGRES_USER=hr
# POSTGRES_PASSWORD=hr
# POSTGRES_DB=hr_service

# API (backend загружает backend/.env или .env; frontend получает URL API)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Feature flags и LLM (переопределяют значения из backend/.env)
# FEATURE_USE_MOCK_LLM=false
# FEATURE_USE_MOCK_HH=false
# FEATURE_USE_MOCK_ESTAFF=false
# ESTAFF_CREATE_CANDIDATE_PATH=/api/candidate/add
# ESTAFF_VACANCIES_PATH=/api/vacancy/find
# ESTAFF_HTTP_VERIFY=true
# ESTAFF_EXPOSE_ERROR_DETAIL=false
# ESTAFF_VACANCIES_CACHE_TTL_SECONDS=120
# HTML-вложение «HR + ИИ» при выгрузке в e-staff (см. backend/.env.example)
# HR_PUBLIC_BASE_URL=http://localhost:3000
# ESTAFF_HR_BUNDLE_ATTACHMENT_TYPE_ID=add_comment
# HH_CLIENT_ID=
# HH_CLIENT_SECRET=
# HH_REDIRECT_URI=http://localhost:8000/api/v1/hh/callback
# Социальный вход (см. backend/.env.example): YANDEX_*, VK_*, FEATURE_USE_MOCK_SOCIAL_OAUTH
# INTERNAL_LLM_ENDPOINT=
# INTERNAL_LLM_API_KEY=
# INTERNAL_LLM_MODEL=
# LLM_FAST_MODEL=  # pre-screening /evaluate; должна быть на сервере Ollama
# LLM_FAST_BATCH_SIZE=5
